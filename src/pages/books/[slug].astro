---
import Layout from "../../Layout.astro";
import { client } from '../../../tina/__generated__/client'
import { TinaMarkdown } from "tinacms/dist/rich-text";

// Create the paths in astro.
export async function getStaticPaths() {
  // Get all the data.
  const { data } = await client.queries.bookConnection()

  // Return an array of routes with params and props from the data.
  return data.bookConnection.edges?.map(edge => ({
    params: { slug: edge.node._sys.filename },
    props: { book: edge.node },
  }));
}

// Get post from props.
const { book } = Astro.props
const formattedDate = new Date(book.pubDate).toDateString()
---

<Layout>
  <article class="py-[80px]">
    <div class="max-w-[720px] mx-auto border-b-2">
      <h1 class="uppercase leading-[96%] hyphens-auto text-balance text-[clamp(42px,8vw,56px)] text-balance">{book.title}</h1>
      <p class="text-right text-[16px] lg:text-[20px]">{formattedDate}</p>
    </div>
    <div class="max-w-[720px] mx-auto py-[56px]">
      <TinaMarkdown content={book.body} />
    </div>
  </article>
</Layout>
